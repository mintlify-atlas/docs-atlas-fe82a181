  "keyFeatures": [
    "JWT authentication with access (24h) and refresh (7d) tokens",
    "Role-based access control: ADMIN, VENDEDOR, ALMACENERO",
    "Product catalog with stock tracking and low-stock alerts",
    "Sales registration with automatic stock deduction and IGV calculation",
    "Purchase order management with receive workflow and stock increment",
    "Inventory movement audit trail (ENTRADA, SALIDA, AJUSTE)",
    "Dashboard with real-time KPIs (daily sales, monthly totals, pending purchases)",
    "PDF report generation for sales and inventory (iTextPDF)",
    "Bulk product import via CSV/JSON with upsert logic",
    "Angular 22 SSR frontend with lazy-loaded feature modules",
    "Docker Compose setup with MySQL 8 and phpMyAdmin",
    "CORS pre-configured for Angular dev server (localhost:4200)"
  ],
